        { "expr": "increase(shadowecho_alerts_fired_total{severity=\"high\"}[5m])", "legendFormat": "High" },
        { "expr": "increase(shadowecho_alerts_fired_total{severity=\"medium\"}[5m])", "legendFormat": "Medium" },
        { "expr": "increase(shadowecho_alerts_fired_total{severity=\"low\"}[5m])", "legendFormat": "Low" }
      ]
    },
